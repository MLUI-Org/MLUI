{
  "appId": "com.mlui.desktop",
  "productName": "MLUI Desktop",
  "directories": {
    "output": "artifacts"
  },
  "files": [
    "dist/**/*",
    "package.json"
  ],
  "artifactName": "${productName}-${version}-${os}-${arch}.${ext}",
  "win": {
    "target": [
      "portable",
      "zip"
    ]
  },
  "linux": {
    "target": [
      "AppImage",
      "tar.gz"
    ],
    "category": "Development"
  },
  "mac": {
    "target": [
      "zip"
    ]
  }
}
