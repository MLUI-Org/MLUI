{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "baseUrl": ".",
    "jsx": "react-jsx",
    "types": ["node", "vitest/globals"],
    "paths": {
      "@desktop/*": ["./src/*"],
      "@mlui/litegraph": ["../../packages/litegraph/dist/litegraph.d.ts"],
      "@mlui/litegraph-addons": ["../../packages/litegraph-addons/src/index.ts"],
      "@mlui/litegraph-nodes": ["../../packages/litegraph-nodes/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "vite.config.ts", "vitest.config.ts"],
  "exclude": ["dist", "release"]
}
