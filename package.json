{
  "name": "@MLUI/Core",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "effect": "4.0.0-beta.43",
      "@effect/atom-react": "4.0.0-beta.43",
      "@effect/platform-bun": "4.0.0-beta.43",
      "@effect/platform-node": "4.0.0-beta.43",
      "@effect/sql-sqlite-bun": "4.0.0-beta.43",
      "@effect/vitest": "4.0.0-beta.43",
      "@effect/language-service": "0.84.2",
      "@types/bun": "^1.3.9",
      "@types/node": "^24.10.13",
      "typescript": "^5.7.3",
      "vitest": "^4.0.0"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo run dev",
    "start": "turbo run start",
    "build": "turbo run build",
    "build:win": "bun run --cwd apps/desktop build:win",
    "typecheck": "turbo run typecheck",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "fmt": "turbo run fmt",
    "fmt:check": "turbo run fmt:check",
    "clean": "rimraf node_modules .turbo apps/*/node_modules apps/*/dist apps/*/release packages/*/node_modules packages/*/dist"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "oxfmt": "^0.40.0",
    "oxlint": "^1.55.0",
    "rimraf": "^6.1.3",
    "turbo": "^2.3.3",
    "typescript": "^6.0.2",
    "vitest": "catalog:"
  },
  "engines": {
    "bun": "^1.3.9",
    "node": "^24.13.1"
  },
  "packageManager": "bun@1.3.9",
  "trustedDependencies": [
    "node-pty"
  ]
}